# --- SerpApi (flights + hotels via Google; free 250 searches/month) ---
# Recommended primary source. Get a key at https://serpapi.com/ .
# With a key, flights use live Google Flights (works for thin routes like
# Kolkata->Port Blair) and hotels use Google Hotels.
SERPAPI_KEY=

# Flight data source: "auto" (SerpApi if key set, else Travelpayouts),
# "serpapi", or "travelpayouts".
FLIGHT_PROVIDER=auto

# --- Travelpayouts / Aviasales (free flights fallback) ---
# Free cached-fare source. Note: the cache often has NO data for thin
# routes / specific future dates, so it's a fallback, not primary.
# Token from Profile -> API token (https://app.travelpayouts.com/profile/api-token).
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_MARKET=

# --- Telegram alerts (required for notifications) ---
# Bot token from @BotFather, chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Supabase (optional; falls back to local JSON if unset) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_service_role_key

# --- Optional overrides ---
# CURRENCY=INR
# CHECK_INTERVAL_HOURS=6

# --- Optional: admin password for a public UI ---
# If set, viewers can see charts but only you (with this password) can edit
# the trip or trigger credit-spending checks. Leave blank for full local access.
APP_ADMIN_PASSWORD=
